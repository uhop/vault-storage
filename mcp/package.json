{
  "name": "vault-storage-mcp",
  "version": "0.0.1",
  "description": "MCP adapter for vault-storage. Exposes the REST API as MCP tools/resources for Claude Code.",
  "type": "module",
  "bin": {
    "vault-storage-mcp": "src/index.ts"
  },
  "files": [
