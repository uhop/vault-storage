{
  "name": "vault-storage",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "AI-agent-first knowledge base over markdown. SQLite + sqlite-vec for fast lookup, semantic search, and typed-edge traversal; BGE embeddings; REST server + MCP adapter.",
  "keywords": [
    "knowledge-base",
    "markdown",
    "vault",
    "obsidian",
    "sqlite",
    "sqlite-vec",
    "vector-search",
    "semantic-search",
    "embeddings",
    "bge",
    "ai-agent",
    "claude",
    "rest-api",
    "typescript"
  ],
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "test": "tape6 --flags FO 'tests/test-*.ts'",
    "start": "node src/index.ts serve",
    "import": "node src/index.ts import",
    "eval": "node eval/embedding-quality.ts",
    "ts-check": "tsc --noEmit",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "sqlite-vec": "^0.1.9",
    "time-queues": "^1.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prettier": "^3.9.5",
    "tape-six": "^1.14.0",
    "typescript": "^7.0.2"
  },
  "github": "https://github.com/uhop/vault-storage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/vault-storage.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/uhop"
  },
  "bugs": {
    "url": "https://github.com/uhop/vault-storage/issues"
  },
  "homepage": "https://github.com/uhop/vault-storage#readme",
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com>",
  "license": "BSD-3-Clause"
}
