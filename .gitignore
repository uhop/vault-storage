node_modules/
dist/
coverage/
.DS_Store
*.log
.env
.env.local

# SQLite databases (derived index — never committed)
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Editor
.vscode/
.idea/

# Claude Code runtime state (lock files, transcripts). Project-level config
# like .claude/settings.json or .claude/agents/* is OK to commit if added.
.claude/*.lock

# Project-level MCP config carries the bearer token in plaintext — keep it
# out of git. Use .mcp.json.example as the committed template.
.mcp.json

# Per-deploy compose extensions (e.g., the Obsidian read-only mount used
# during cutover). docker compose auto-merges compose.override.yaml on top
# of the base compose.yaml. See compose.override.yaml.example for the
# cutover template.
compose.override.yaml
