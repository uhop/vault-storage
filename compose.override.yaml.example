# Per-deploy override. `docker compose` reads compose.override.yaml
# automatically and merges it on top of the base compose.yaml. This file
# (the .example template) is committed; the real compose.override.yaml is
# gitignored so per-host paths don't leak into the repo.
#
# Use case (currently): Obsidian → vault-data sync during the cutover from
# Obsidian. Mount your live Obsidian vault read-only at /obsidian inside
# the container so `POST /sync/from-obsidian` (and the
# `/vault sync-from-obsidian` skill) can walk it.
#
# Setup on a fresh deploy:
#   cp compose.override.yaml.example compose.override.yaml
#   $EDITOR compose.override.yaml         # set your real Obsidian path
#   docker compose up -d                  # recreates the container with the new mount
#
# Once Obsidian is retired, delete compose.override.yaml and `docker compose
# up -d` to drop the mount cleanly.

services:
  vault-storage:
    volumes:
      # Read-only bind of your Obsidian vault. The path on the LEFT is the
      # absolute host path; the path on the RIGHT is the container-side
      # path the server reads from (matches OBSIDIAN_VAULT_PATH=/obsidian
      # in the base compose.yaml's `environment:` block).
      - "/absolute/path/to/your/obsidian/vault:/obsidian:ro"
