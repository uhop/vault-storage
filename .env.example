# Bearer token for REST + MCP authentication. Generate a strong random value.
VAULT_API_TOKEN=

# Path to the cloned vault-data repository (the markdown source of truth).
VAULT_DATA_PATH=./vault-data

# Path to the SQLite index file. Created on first run.
VAULT_DB_PATH=./vault.sqlite

# Listen address + port for the REST server.
VAULT_HOST=127.0.0.1
VAULT_PORT=8090

# Embedding model (Hugging Face / Xenova ONNX). 384-dim default.
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5

# Tier 2 backup (optional). Leave empty to disable.
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
