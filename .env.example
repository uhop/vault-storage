# Copy to `.env` and edit. The compose file reads from `.env` automatically.

# ── Required ──────────────────────────────────────────────────────────────────

# Bearer token for every API request. Generate with: openssl rand -hex 32
VAULT_API_TOKEN=replace-me-with-a-real-token

# Absolute host path to your markdown vault. The container mounts this at
# /data and treats it as the source of truth (read-write).
VAULT_DATA_PATH_HOST=/path/to/your/vault-data

# ── Network ───────────────────────────────────────────────────────────────────

# Port the API listens on (host side). Default 8123.
VAULT_PORT=8123

# Host interface to publish on. Default 0.0.0.0 (all interfaces — remote access).
# Use 127.0.0.1 for local-only, or your LAN IP to limit to that subnet.
VAULT_PUBLISH_HOST=0.0.0.0

# ── Behavior ──────────────────────────────────────────────────────────────────

# Run a full reindex on container start (default true). Cheap if the DB is
# already in sync; a no-op for unchanged files.
VAULT_AUTO_REINDEX=true

# Watch the vault tree and reindex incrementally on .md changes (default true).
VAULT_AUTO_WATCH=true

# Debounce window in ms before processing a batch of file changes (default 1500).
VAULT_WATCH_DEBOUNCE_MS=1500

# Embedder backend: 'bge' (real, ~150 MB model) or 'fake' (deterministic, no
# semantic value — useful for smoke tests only). Default 'bge'.
VAULT_EMBEDDER=bge

# ── Backup (Tier 1, optional) ─────────────────────────────────────────────────

# When true, a polling loop runs `git add -A && git commit` against the vault
# tree on a schedule so working-tree changes don't sit uncommitted forever
# (default true). No-op when the path isn't a git repo.
VAULT_AUTO_COMMIT=true

# When true (default false), also `git push` after each commit. Requires the
# remote to accept whatever credentials the container has — set this to true
# only if you've mounted SSH keys into ~/.ssh or set up an HTTPS token in the
# remote URL.
VAULT_AUTO_PUSH=false

# Polling interval for auto-commit, in ms. Default 60000 (one minute).
VAULT_COMMIT_INTERVAL_MS=60000

# ── File ownership (advanced) ─────────────────────────────────────────────────

# Match these to your host user so volume-mounted writes have sane ownership.
# Run `id -u` and `id -g` to find yours; the compose defaults to 1000:1000.
VAULT_UID=1000
VAULT_GID=1000
