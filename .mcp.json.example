{
  "_help": "Project-scope MCP config for Claude Code. Copy this file to .mcp.json (gitignored), fill in VAULT_API_URL + VAULT_API_TOKEN, and restart Claude Code. The bearer token is a secret — do NOT commit .mcp.json.",
  "_command_options": {
    "recommended": "Run from npm: set 'command' to 'npx' and 'args' to ['-y', '@uhop/vault-storage-mcp@latest'] (as below).",
    "local_checkout": "Without npm: set 'command' to 'node' and 'args' to ['/abs/path/to/vault-storage/mcp/src/index.js']."
  },
  "mcpServers": {
    "vault": {
      "command": "npx",
      "args": ["-y", "@uhop/vault-storage-mcp@latest"],
      "env": {
        "VAULT_API_URL": "http://your-host:8123",
        "VAULT_API_TOKEN": "<paste-bearer-token-here>"
      }
    }
  }
}
